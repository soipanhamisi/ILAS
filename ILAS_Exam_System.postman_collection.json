    {
      "name": "Admin Monitoring Mini",
      "item": [
        {
          "name": "1) Admin Login (capture adminId)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"userType\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Login success envelope', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data).to.be.an('object');",
                  "  pm.expect(json.data.userId).to.be.a('number');",
                  "  pm.expect(json.data.userType).to.eql('admin');",
                  "});",
                  "",
                  "pm.collectionVariables.set('adminId', String(json.data.userId));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2) Dashboard Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard/summary?adminId={{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard",
                "summary"
              ],
              "query": [
                {
                  "key": "adminId",
                  "value": "{{adminId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Summary response is valid', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data).to.be.an('object');",
                  "  pm.expect(json.data).to.have.property('totalStudents');",
                  "  pm.expect(json.data).to.have.property('totalInstructors');",
                  "  pm.expect(json.data).to.have.property('totalCourses');",
                  "  pm.expect(json.data).to.have.property('totalExams');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3) Monitoring Poll (baseline)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard/monitoring?adminId={{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard",
                "monitoring"
              ],
              "query": [
                {
                  "key": "adminId",
                  "value": "{{adminId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Monitoring payload shape', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data).to.be.an('object');",
                  "  pm.expect(json.data).to.have.property('threadPoolCapacity');",
                  "  pm.expect(json.data).to.have.property('globalActiveRequests');",
                  "  pm.expect(json.data).to.have.property('globalUtilization');",
                  "  pm.expect(json.data).to.have.property('endpointHealth');",
                  "  pm.expect(json.data).to.have.property('users');",
                  "  pm.expect(json.data).to.have.property('series');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4) Heartbeat (admin)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/monitoring/heartbeat?userType=admin&userId={{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "monitoring",
                "heartbeat"
              ],
              "query": [
                {
                  "key": "userType",
                  "value": "admin"
                },
                {
                  "key": "userId",
                  "value": "{{adminId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Heartbeat accepted', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "5) Monitoring Poll (after heartbeat)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard/monitoring?adminId={{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard",
                "monitoring"
              ],
              "query": [
                {
                  "key": "adminId",
                  "value": "{{adminId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Monitoring after heartbeat remains healthy', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.users).to.be.an('object');",
                  "  pm.expect(json.data.users).to.have.property('activeUsers');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "6) Negative - Invalid Admin ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard/monitoring?adminId=999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard",
                "monitoring"
              ],
              "query": [
                {
                  "key": "adminId",
                  "value": "999999"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 with failure envelope', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Invalid admin is rejected', function () {",
                  "  pm.expect(json.success).to.eql(false);",
                  "  pm.expect(json.message).to.be.a('string');",
                  "  pm.expect(json.message.toLowerCase()).to.include('admin');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
