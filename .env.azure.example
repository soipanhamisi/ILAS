# Azure App Service / Container App settings for backend
SPRING_PROFILES_ACTIVE=prod

# Database (Azure Database for MySQL)
DB_URL=jdbc:mysql://<mysql-host>:3306/ilasdb?useSSL=true&requireSSL=true
DB_USERNAME=<db-user>
DB_PASSWORD=<db-password>

# Optional: if not using PORT/WEBSITES_PORT from Azure
ILAS_SERVER_PORT=8080

# File upload storage path (App Service Linux writable path)
FILE_STORAGE_UPLOAD_DIR=/home/site/wwwroot/storage/exam-assessments

# LLM provider config (Gemini example)
GRADING_LLM_PROVIDER=gemini-studio
GEMINI_STUDIO_ENDPOINT_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_STUDIO_MODEL=gemini-flash-latest
GEMINI_STUDIO_API_KEY=<your-gemini-key>

