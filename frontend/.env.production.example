# Azure frontend config
# If frontend and backend are hosted on different domains, set full backend URL:
# VITE_API_BASE_URL=https://your-backend-app.azurewebsites.net/api
# If hosted behind same domain/proxy, you can keep /api
VITE_API_BASE_URL=/api

# Optional local dev override for Vite proxy target
# VITE_DEV_API_PROXY_TARGET=http://localhost:8080
